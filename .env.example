# App
APP_NAME="Podcast Summarizer MVP"
ENV="dev"
LOG_LEVEL="INFO"
DATA_DIR="data"

# OpenAI
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-mini"

# faster-whisper
WHISPER_MODEL_SIZE="base"
WHISPER_COMPUTE_TYPE="int8"
WHISPER_DEVICE="cpu"

# Summarization chunking
MAP_CHUNK_CHARS="6000"

# Market data (Financial Modeling Prep)
FMP_API_KEY=""
FMP_BASE_URL="https://financialmodelingprep.com"
FMP_TIMEOUT_SECONDS="20"

# Market provider: yahoo (default) or fmp
MARKET_DATA_PROVIDER="yahoo"
YAHOO_UNIVERSE_SYMBOLS="AAPL,MSFT,NVDA,AMZN,GOOGL,GOOG,META,TSLA,BRK-B,AVGO,LLY,WMT,JPM,V,UNH,XOM,MA,COST,PG,HD,ORCL,NFLX,MRK,ABBV,CVX,KO,ADBE,CRM,AMD,PEP,LIN,BAC,ACN,MCD,TMO,CSCO,ABT,WFC,GE,DIS,QCOM,DHR,VZ,INTU,PM,CAT,TXN,INTC,PFE,IBM,AMAT,NOW,UBER,BX,GS,MS"
